{
  "name": "@stopgame/schemas",
  "version": "0.0.0",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "tsc --watch",
    "build": "tsc"
  },
  "exports": {
    "./error": {
      "types": "./src/error.ts"
    },
    "./room": {
      "default": "./dist/room.js",
      "types": "./src/room.ts"
    },
    "./player": {
      "default": "./dist/player.js",
      "types": "./src/player.ts"
    },
    "./socket": {
      "types": "./src/socket/index.ts"
    },
    "./socket/acknowledgements": {
      "types": "./src/socket/acknowledgements.ts"
    },
    "./socket/clientToServer/*": {
      "default": "./dist/socket/clientToServerEvents/*Schemas.js",
      "types": "./src/socket/clientToServerEvents/*Schemas.ts"
    }
  },
  "dependencies": {
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@stopgame/eslint-config": "workspace:*",
    "@stopgame/typescript-config": "workspace:*",
    "eslint": "^10.0.3"
  }
}
